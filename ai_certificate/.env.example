# ==============================
# Application Configuration
# ==============================
APP_NAME=AI Certificate Analyzer
APP_VERSION=2024.2.0
DEBUG=false
LOG_LEVEL=INFO

# ==============================
# Server Configuration
# ==============================
HOST=0.0.0.0
PORT=8001
WORKERS=4
RELOAD=false

# ==============================
# Redis Configuration
# ==============================
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# ==============================
# OCR Configuration
# ==============================
# Languages: eng (English), amh (Amharic)
OCR_LANGUAGES=eng+amh

# Tesseract data path (REQUIRED for Windows)
# Windows: C:\Program Files\Tesseract-OCR\tessdata
# Linux: /usr/share/tesseract-ocr/4.00/tessdata
# macOS: /usr/local/share/tessdata
TESSDATA_PATH=

# Enable PaddleOCR (alternative OCR engine)
USE_PADDLEOCR=false

# ==============================
# ML Models Configuration
# ==============================
# Enable ML models (Donut parser, field extractor)
USE_ML=true

# ML confidence threshold (0.0 - 1.0)
ML_CONFIDENCE_THRESHOLD=0.6

# Path to Donut model directory
DONUT_MODEL_PATH=app/models/donut_certificate

# ==============================
# Analysis Thresholds
# ==============================
# Reject threshold: Below this score, auto-reject (0.0 - 1.0)
REJECT_THRESHOLD=0.65

# Low quality threshold: Flag low quality scans (0.0 - 1.0)
LOW_QUALITY_THRESHOLD=0.7

# Tampering threshold: Tampering detection sensitivity (0.0 - 1.0)
TAMPERING_THRESHOLD=0.75

# ==============================
# Security Configuration
# ==============================
# API key header name
API_KEY_HEADER=X-API-Key

# Allowed CORS origins (comma-separated or *)
# Production: https://yourdomain.com,https://api.yourdomain.com
# Development: *
ALLOWED_ORIGINS=*

# API key (set in production)
# API_KEY=your-secret-api-key-here

# ==============================
# Storage Configuration
# ==============================
# Upload directory for temporary files
UPLOAD_DIR=uploads

# Training data directory
TRAINING_DATA_DIR=data/training

# Models directory
MODELS_DIR=models

# ==============================
# Performance Configuration
# ==============================
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# Maximum worker threads for CPU-bound tasks
# Reduce to 2 for 8GB RAM systems
MAX_WORKERS=4

# Batch processing size
# Reduce to 10-15 for 8GB RAM systems
BATCH_SIZE=25

# ==============================
# Optional: Database (Future)
# ==============================
# DATABASE_URL=postgresql://user:password@localhost/certanalyzer

# ==============================
# Optional: Monitoring
# ==============================
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000

# ==============================
# Optional: Logging
# ==============================
# LOG_FILE=logs/app.log
# LOG_MAX_SIZE=10485760
# LOG_BACKUP_COUNT=5
